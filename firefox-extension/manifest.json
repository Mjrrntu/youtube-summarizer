{
  "manifest_version": 3,
  "name": "AI YouTube Summary",
  "version": "0.2",
  "description": "Summarize current YouTube video using local AI pipeline.",
  "permissions": ["tabs", "activeTab"],
  "host_permissions": [
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "https://www.youtube.com/*"
  ],
  "action": {
    "default_title": "AI-yhteenveto",
    "default_popup": "popup.html"
  }
}
